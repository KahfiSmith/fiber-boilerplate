APP_NAME=fiber-boilerplate
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
APP_READ_TIMEOUT=10s
APP_WRITE_TIMEOUT=10s
APP_SHUTDOWN_TIMEOUT=10s
APP_BODY_LIMIT_MB=4
APP_PREFORK=false

LOG_LEVEL=info
LOG_ENCODING=console

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fiber_boilerplate
DB_SSLMODE=disable
DB_TIMEZONE=UTC
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=5m
