APP_NAME=fiber-boilerplate
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
APP_READ_TIMEOUT=10s
APP_WRITE_TIMEOUT=10s
APP_SHUTDOWN_TIMEOUT=10s
APP_BODY_LIMIT_MB=4
APP_PREFORK=false
# Legacy aliases still supported:
# HTTP_ADDR=:3000
# GRACEFUL_SHUTDOWN_MS=10000

LOG_LEVEL=info
LOG_ENCODING=console

DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=kahfismith
DB_NAME=boilerplate
DB_SSLMODE=disable
DB_TIMEZONE=UTC
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=2m

REDIS_ADDR=127.0.0.1:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=fiber-boilerplate

GENERATE_SWAGGER_ON_MIGRATE=true

JWT_SECRET=replace-with-strong-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
BCRYPT_COST=12
AUTH_RATE_LIMIT_PER_MINUTE=5
AUTH_OTP_TTL=5m
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_DEBUG_EXPOSE_OTP=false
# Legacy alias still supported:
# AUTH_DEBUG_EXPOSE_TOKENS=false

# Optional and currently unused by this backend:
# FRONTEND_BASE_URL=http://localhost:5173
